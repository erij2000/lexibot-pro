# Define the base URL for your FastAPI backend
API_BASE_URL ="http://backend:8000"

# Define your default model name (used in session state initialization)
MODEL_DEFAULT = "lexi-o3"

# Define the full API endpoint for the chatbot interaction
API_URL = f"{API_BASE_URL}/chatbot/ask"

# Model mapping: Maps the display name (key) to the actual Ollama model name (value)
MODEL_MAPPING = {
    "lexi-o1": "phi3:mini",
    "lexi-o2": "llama3:instruct", 
    "lexi-o3": "mistral:instruct"
}

# Dummy Avatars (Replace with actual URLs if needed)
USER_AVATAR = "👤"
BOT_AVATAR = "⚖️"
