@keyframes spin-slow {{ from {{ transform: rotate(0deg); }} to {{ transform: rotate(360deg); }} }}
.lexi-logo-badge svg .ring {{ animation: spin-slow 18s linear infinite; transform-origin: 32px 32px; }}
</style>
"""     
# ✅ ADD THIS LINE - Inject the CSS immediately
st.markdown(get_css(st.session_state.ui_lang), unsafe_allow_html=True)

# For compatibility with older Streamlit versions
def rerun():
    """Compatible rerun function for different Streamlit versions"""
    try:
        st.rerun()  # Newer versions
    except AttributeError:
        try:
            st.experimental_rerun()  # Older versions
        except AttributeError:
            st.write("Please refresh the page manually")

# Typing sound functionality
def play_typing_sound(language):
    """Play audible typing click sounds repeatedly during the typing indicator.
    Uses WebAudio API and ensures the AudioContext is resumed on user gesture.
    """
    typing_sound_js = """
    <script>
    // Create (or reuse) a global audio context
    window.__lexiAudioCtx = window.__lexiAudioCtx || new (window.AudioContext || window.webkitAudioContext)();

    async function ensureAudio() {
        try {
            if (window.__lexiAudioCtx.state === 'suspended') {
                await window.__lexiAudioCtx.resume();
            }
        } catch (e) {
            console.log('Audio resume failed:', e);
        }
    }

    function clickOnce() {
        try {
            const ctx = window.__lexiAudioCtx;
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            
            osc.type = 'triangle';
            osc.frequency.value = 1200; // crisp click frequency
            gain.gain.value = 0.15; // audible volume
            
            osc.connect(gain);
            gain.connect(ctx.destination);
            
            const now = ctx.currentTime;
            gain.gain.setValueAtTime(0.15, now);
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.06);
            
            osc.start(now);
            osc.stop(now + 0.06);
        } catch (e) {
            console.log('Click sound failed:', e);
        }
    }

    (async () => {
        await ensureAudio();
        // Play a short click every 120ms for about 3 seconds
        let clickCount = 0;
        const maxClicks = 25;
        const interval = setInterval(() => {
            clickOnce();
            clickCount++;
            if (clickCount >= maxClicks) {
                clearInterval(interval);
            }
        }, 120);
    })();
    </script>
    """
    return typing_sound_js

# Conversation history management (with file persistence)
DATA_DIR = Path("data")
CONV_FILE = DATA_DIR / "conversations.json"

def _ensure_data_dir():
    try:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
    except Exception:
        pass

def _save_history_to_file():
    _ensure_data_dir()
    try:
        with open(CONV_FILE, "w", encoding="utf-8") as f:
            json.dump(st.session_state.conversation_history, f, ensure_ascii=False, indent=2)
    except Exception:
        pass

def _load_history_from_file():
    try:
        if CONV_FILE.exists():
            with open(CONV_FILE, "r", encoding="utf-8") as f:
                st.session_state.conversation_history = json.load(f)
    except Exception:
        pass

# Initial load from disk (once)
if not st.session_state.get("_history_loaded", False):
    _load_history_from_file()
    st.session_state._history_loaded = True


def save_conversation():
    """Save current conversation to history and persist to disk"""
    if st.session_state.chat and len(st.session_state.chat) > 0:
        # Get first user message as title
        title = "Nouvelle conversation"
        for msg in st.session_state.chat:
            if msg["role"] == "user" and msg["text"].strip():
                # Clean the text and take first meaningful part
                clean_text = msg["text"].strip()
                if len(clean_text) > 30:
                    title = clean_text[:30] + "..."
                else:
                    title = clean_text
                break
        
        conversation = {
            "id": int(time.time()*1000),
            "title": title,
            "messages": st.session_state.chat.copy(),
              # Remplace la ligne du timestamp par celle-ci (qui utilise le module time que tu as déjà) :
            "timestamp": time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()),
            "lang": st.session_state.ui_lang
        }
        
        st.session_state.conversation_history.insert(0, conversation)
        # Keep only last 50 conversations
        if len(st.session_state.conversation_history) > 50:
            st.session_state.conversation_history = st.session_state.conversation_history[:50]
        _save_history_to_file()
        st.session_state.unsaved_changes = False
        st.session_state.auto_saved = True


def load_conversation(conv_id):
    """Load a conversation from history"""
    for conv in st.session_state.conversation_history:
        if conv["id"] == conv_id:
            st.session_state.chat = conv["messages"].copy()
            st.session_state.current_conversation_id = conv_id
            break

def start_new_conversation(save_before=True):
    """Start a new conversation"""
    if save_before and st.session_state.chat:
        save_conversation()
    st.session_state.chat = []
    st.session_state.current_conversation_id = None
    st.session_state.unsaved_changes = False

