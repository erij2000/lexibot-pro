# ---------- AUTO-LOGIN & CLIENT AUTH ----------
def auto_login_from_storage():
    """Restore JWT from browser localStorage into session and validate it.
    Uses a safe URL param bridge to communicate the token from JS to Python, then cleans the URL.
    """
    try:
        # Step 1: If no token in session, ask JS to expose localStorage token in URL temporarily
        if not st.session_state.get("jwt_token"):
            components.html(
                """
                <script>
                (function(){
                  try {
                    const t = window.parent.localStorage.getItem('lexibot_token');
                    if (t) {
                      const url = new URL(window.parent.location.href);
                      if (url.searchParams.get('lexi_token') !== t) {
                        url.searchParams.set('lexi_token', t);
                        window.parent.history.replaceState({}, '', url.toString());
                      }
                    }
                  } catch(e) {}
                })();
                </script>
                """,
                height=0
            )

        # Step 2: Python reads the token from query params
        params = st.experimental_get_query_params()
        token_param = params.get('lexi_token', [None])[0]
        if token_param and not st.session_state.get("jwt_token"):
            # Validate token by calling protected endpoint
            try:
                resp = requests.get(
                    f"{API_BASE_URL}/users/me",
                    headers={"Authorization": f"Bearer {token_param}"},
                    timeout=5
                )
                if resp.status_code == 200:
                    st.session_state.jwt_token = token_param
                    st.session_state.user_info = resp.json()
                else:
                    # Invalid token: clear from browser storage
                    components.html(
                        """
                        <script>
                        try { window.parent.localStorage.removeItem('lexibot_token'); } catch(e) {}
                        </script>
                        """,
                        height=0
                    )
            except Exception:
                pass

        # Step 3: Clean URL to remove any token traces
        if token_param:
            components.html(
                """
                <script>
                (function(){
                  try {
                    const url = new URL(window.parent.location.href);
                    url.searchParams.delete('lexi_token');
                    window.parent.history.replaceState({}, '', url.toString());
                  } catch(e) {}
                })();
                </script>
                """,
                height=0
            )
    except Exception:
        # Silent fail: do not break UI if auto-restore fails
        pass

def show_client_auth():
    """Clean multilingual client authentication interface"""
    current_token = st.session_state.get("jwt_token", "")
    user_info = st.session_state.get("user_info", {})

