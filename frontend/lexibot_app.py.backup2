            placeholder="Décrivez brièvement votre situation...",
            max_chars=500
        )
        
        submit_appointment = st.form_submit_button("📅 Demander le rendez-vous", use_container_width=True)
        
        if submit_appointment:
            success, result = request_appointment(subject, preferred_date.isoformat(), preferred_time, description)
            if success:
                st.success("✅ Demande envoyée! Vous recevrez une confirmation par email.")
            else:
                st.error(f"❌ {result}")
    
    # --- Show user's appointments ---
    st.markdown("### 📋 Mes Rendez-vous")
    try:
        user_appointments = get_user_appointments()
        if user_appointments:
            for apt in user_appointments:
                status_icon = {"pending": "⏳", "approved": "✅", "rejected": "❌"}.get(apt["status"], "❓")
                st.markdown(f"""
                **{status_icon} {apt['subject']}**  
                📅 {apt['preferred_date']} à {apt.get('preferred_time', 'N/A')}  
                Status: {apt['status']}
                """)
        else:
            st.info("Aucun rendez-vous pour le moment")
    except Exception:
        st.info("Aucun rendez-vous pour le moment")


# Floating sidebar toggle and dynamic logo
# Localize toggle and logo titles
_toggle_titles = { 'fr': 'Afficher/Masquer la barre latérale', 'en': 'Show/Hide sidebar', 'ar': 'إظهار/إخفاء الشريط الجانبي' }
_logo_titles = { 'fr': 'Ouvrir le menu Lexibot', 'en': 'Open Lexibot menu', 'ar': 'فتح قائمة ليكسيبوت' }
_toggle_title = _toggle_titles.get(st.session_state.ui_lang, 'Show/Hide sidebar')
_logo_title = _logo_titles.get(st.session_state.ui_lang, 'Open Lexibot menu')

st.markdown(f"""
<div id=\"lexiToggle\" class=\"lexi-toggle\" title=\"{_toggle_title}\" role=\"button\" tabindex=\"0\" aria-label=\"{_toggle_title}\">«</div>
<div id=\"lexiLogo\" class=\"lexi-logo-badge\" title=\"{_logo_title}\" role=\"button\" tabindex=\"0\" aria-label=\"{_logo_title}\">
  <svg viewBox=\"0 0 64 64\" width=\"36\" height=\"36\" aria-hidden=\"true\">
    <defs>
      <linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">
        <stop offset=\"0%\" stop-color=\"#d4af37\"/>
        <stop offset=\"100%\" stop-color=\"#b8941f\"/>
      </linearGradient>
    </defs>
    <!-- Scale of justice -->
    <circle class=\"ring\" cx=\"32\" cy=\"32\" r=\"28\" fill=\"none\" stroke=\"url(#g1)\" stroke-width=\"2\" opacity=\"0.7\"/>
    <rect x=\"30\" y=\"18\" width=\"4\" height=\"24\" fill=\"url(#g1)\"/>
    <rect x=\"24\" y=\"18\" width=\"16\" height=\"4\" rx=\"2\" fill=\"url(#g1)\"/>
    <path d=\"M20 26 L28 26 L24 36 Z\" fill=\"none\" stroke=\"#d4af37\" stroke-width=\"2\"/>
    <path d=\"M36 26 L44 26 L40 36 Z\" fill=\"none\" stroke=\"#d4af37\" stroke-width=\"2\"/>
    <!-- Crescent & star (Tunisia) -->
    <circle cx=\"46\" cy=\"20\" r=\"6\" fill=\"#e11d48\"/>
    <circle cx=\"44.5\" cy=\"20\" r=\"5\" fill=\"#0f172a\"/>
    <polygon points=\"46,16.5 47,19 49.7,19.2 47.5,20.8 48.2,23.3 46,21.9 43.8,23.3 44.5,20.8 42.3,19.2 45,19\" fill=\"#f8fafc\"/>
  </svg>
</div>
""", unsafe_allow_html=True)

# Run toggle logic in an iframe so scripts execute (Streamlit sanitizes <script> in markdown)
components.html("""
<!DOCTYPE html>
<html>
<head><meta charset=\"utf-8\"></head>
<body style=\"margin:0; padding:0; background:transparent;\">
<script>
(function(){
  const doc = window.parent.document;
  let initialized = false;
  
  function qs(s){ return doc.querySelector(s); }
  
  function dir(){
    try { return doc.defaultView.getComputedStyle(doc.documentElement).direction || 'ltr'; }
    catch(e){ return 'ltr'; }
  }
  
  function setDirClasses(){
    const isRTL = dir() === 'rtl';
    doc.body.classList.toggle('lexi-rtl', isRTL);
    doc.body.classList.toggle('lexi-ltr', !isRTL);
  }
  
  function ensureElements(){
    let t = qs('#lexiToggle');
    if(!t){
      t = doc.createElement('div');
      t.id = 'lexiToggle';
      t.className = 'lexi-toggle';
      t.setAttribute('role','button');
      t.setAttribute('tabindex','0');
      t.setAttribute('title','Show/Hide sidebar');
      t.setAttribute('aria-pressed','false');
      t.style.cssText = 'position:fixed;top:16px;left:16px;z-index:99999;';
      doc.body.appendChild(t);
    }
    let l = qs('#lexiLogo');
    if(!l){
      l = doc.createElement('div');
      l.id = 'lexiLogo';
      l.className = 'lexi-logo-badge';
      l.setAttribute('role','button');
      l.setAttribute('tabindex','0');
      l.setAttribute('title','Open Lexibot menu');
      l.style.zIndex = '99998';
      l.innerHTML = '<svg viewBox="0 0 64 64" width="36" height="36" aria-hidden="true"><defs><linearGradient id="g1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#d4af37"/><stop offset="100%" stop-color="#b8941f"/></linearGradient></defs><circle class="ring" cx="32" cy="32" r="28" fill="none" stroke="url(#g1)" stroke-width="2" opacity="0.7"/><rect x="30" y="18" width="4" height="24" fill="url(#g1)"/><rect x="24" y="18" width="16" height="4" rx="2" fill="url(#g1)"/><path d="M20 26 L28 26 L24 36 Z" fill="none" stroke="#d4af37" stroke-width="2"/><path d="M36 26 L44 26 L40 36 Z" fill="none" stroke="#d4af37" stroke-width="2"/><circle cx="46" cy="20" r="6" fill="#e11d48"/><circle cx="44.5" cy="20" r="5" fill="#0f172a"/><polygon points="46,16.5 47,19 49.7,19.2 47.5,20.8 48.2,23.3 46,21.9 43.8,23.3 44.5,20.8 42.3,19.2 45,19" fill="#f8fafc"/></svg>';
      doc.body.appendChild(l);
    }
  }
  
  function getSidebar(){ return qs('section[data-testid="stSidebar"]'); }
  
  function isSidebarVisible(){
    try {
      const s = getSidebar();
      if(!s) return false;
      const st = doc.defaultView.getComputedStyle(s);
      const w = parseFloat(st.width) || 0;
      return st.display !== 'none' && st.visibility !== 'hidden' && parseFloat(st.opacity) > 0.1 && w > 10;
    } catch(e){ return false; }
  }
  
  function hideTransform(){
    return dir()==='rtl' ? 'translateX(110%)' : 'translateX(-110%)';
  }
  
  function applyInlineState(open){
    const s = getSidebar();
    if(!s) return;
    
    if(open){
      s.style.cssText = 'min-width: 300px !important; max-width: 420px !important; height: 100vh !important; transform: none !important; opacity: 1 !important; pointer-events: auto !important; width: auto !important; margin: auto !important; padding-top: var(--space-5) !important; border-right: 1px solid rgba(212, 175, 55, 0.25) !important; overflow-y: auto !important; overflow-x: hidden !important;';
    } else {
      s.style.cssText = `transform: ${hideTransform()} !important; opacity: 0 !important; pointer-events: none !important; width: 0px !important; min-width: 0px !important; max-width: 0px !important; height: 0px !important; margin: 0 !important; padding: 0 !important; border-right: 0 !important; overflow: hidden !important;`;
    }
  }
  
  function updateToggleLabel(collapsed){
    const t = qs('#lexiToggle');
    if(!t) return;
    const isRTL = dir() === 'rtl';
    const collapsedChar = isRTL ? '›' : '«';
    const expandedChar = isRTL ? '‹' : '»';
    t.textContent = collapsed ? collapsedChar : expandedChar;
    t.setAttribute('aria-pressed', collapsed ? 'true' : 'false');
  }
  
  function setCollapsed(flag){
    if(!initialized) return;
    
    console.log('Setting sidebar collapsed:', flag);
    
    // Update body classes
    doc.body.classList.toggle('lexi-sb-collapsed', flag);
    
    // Save state
    try { 
      window.parent.localStorage.setItem('lexi_sb_c', flag ? '1' : '0'); 
    } catch(e){
      console.log('Failed to save sidebar state:', e);
    }
    
    // Update toggle label
    updateToggleLabel(flag);
    
    // Apply visual state
    applyInlineState(!flag);
    
    // Force a small delay to ensure styles are applied
    setTimeout(() => applyInlineState(!flag), 50);
  }
  
  function getCurrentState(){
    // Check both localStorage and current DOM state
    let savedState = false;
    try { 
      savedState = (window.parent.localStorage.getItem('lexi_sb_c') === '1'); 
    } catch(e){}
    
    const hasCollapsedClass = doc.body.classList.contains('lexi-sb-collapsed');
    const visible = isSidebarVisible();
    
    // Use DOM state as source of truth if different from localStorage
    return hasCollapsedClass || (!visible && savedState);
  }
  
  function wire(){
    const t = qs('#lexiToggle');
    if(t && !t._wired){
      t._wired = true;
      t.onclick = function(e){ 
        e.preventDefault();
        e.stopPropagation();
        const currentlyCollapsed = getCurrentState();
        setCollapsed(!currentlyCollapsed);
      };
      t.onkeydown = function(e){ 
        if(e.key==='Enter' || e.key===' '){ 
          e.preventDefault(); 
          t.click(); 
        } 
      };
    }
    
    const l = qs('#lexiLogo');
    if(l && !l._wired){
      l._wired = true;
      l.onclick = function(e){ 
        e.preventDefault();
        e.stopPropagation();
        setCollapsed(false);
      };
      l.onkeydown = function(e){ 
        if(e.key==='Enter' || e.key===' '){ 
          e.preventDefault(); 
          l.click(); 
        } 
      };
    }
    
    // Global keyboard shortcut
    if(!doc._keydownWired){
      doc._keydownWired = true;
      doc.addEventListener('keydown', function(e){
        if((e.ctrlKey || e.metaKey) && (e.key && e.key.toLowerCase() === 'b')){
          e.preventDefault();
          const currentlyCollapsed = getCurrentState();
          setCollapsed(!currentlyCollapsed);
        }
      });
    }
  }
  
  function init(){
    if(initialized) return;
    
    try{
      console.log('Initializing sidebar toggle...');
      
      setDirClasses();
      ensureElements();
      
      // Get initial state
      const savedState = getCurrentState();
      console.log('Initial sidebar state (collapsed):', savedState);
      
      // Set initial state
      doc.body.classList.toggle('lexi-sb-collapsed', savedState);
      updateToggleLabel(savedState);
      applyInlineState(!savedState);
      
      // Wire up event handlers
      wire();
      
      initialized = true;
      console.log('Sidebar toggle initialized successfully');
      
      // Set up observer to maintain state
      const mo = new MutationObserver(function(){
        if(!initialized) return;
        setDirClasses();
        ensureElements();
        
        // Re-wire if needed
        const t = qs('#lexiToggle');
        const l = qs('#lexiLogo');
        if(t && !t._wired) wire();
        if(l && !l._wired) wire();
        
        // Maintain current state
        const currentState = getCurrentState();
        applyInlineState(!currentState);
      });
      mo.observe(doc.body, {childList: true, subtree: true});
      
    } catch(e){ 
      console.log('Sidebar toggle init error:', e);
    }
  }
  
  function waitForStreamlit(attempts){
    if(attempts <= 0) { 
      console.log('Max attempts reached, initializing anyway');
      init(); 
      return; 
    }
    
    const sidebar = getSidebar();
    if(sidebar){
      console.log('Streamlit sidebar found, initializing');
      setTimeout(init, 100); // Small delay to ensure Streamlit is fully loaded
      return;
    }
    
    setTimeout(function(){ waitForStreamlit(attempts - 1); }, 200);
  }
  
  // Start the initialization process
  waitForStreamlit(25); // Increased attempts
  
})();
</script>
</body>
</html>
""", height=0, width=0)

# Auto-save on inactivity (5 minutes)
now_ts = time.time()
if st.session_state.unsaved_changes and not st.session_state.auto_saved:
    if now_ts - st.session_state.last_interaction > 300:
        save_conversation()


# ---------- SIDEBAR ----------
with st.sidebar:
    st.markdown(f"""
    <div class="glass-card" style="position: sticky; top: 0; z-index: 999; background: rgba(31, 41, 55, 0.95); backdrop-filter: blur(10px);">
        <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 0.5rem;">
            <span style="font-size: 1.5rem; margin-right: 8px;">⚖️</span>
            <span style="font-size: 1rem; font-weight: bold; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
                Lexibot • <span style="color: #d4af37;">Hila Ben Arbia</span>
            </span>
        </div>
        <div style="text-align: center; font-size: 0.8rem; color: #9ca3af;">
            {lang_flags[st.session_state.ui_lang]} {lang_names[st.session_state.ui_lang]}
        </div>
    </div>
    """, unsafe_allow_html=True)
    
    # Language selector
    ui_lang = st.selectbox(
        "🌐 UI Language / لغة الواجهة",
        ["fr", "en", "ar"],
        index=["fr", "en", "ar"].index(st.session_state.ui_lang),
        format_func=lambda k: f"{lang_flags[k]} {lang_names[k]}"
    )
    
    if ui_lang != st.session_state.ui_lang:
        st.session_state.ui_lang = ui_lang
        rerun()
    
    # Auto language detection
    auto_lang = st.checkbox(texts["auto_lang"][ui_lang], value=True)
    
    # Model selection with custom names (reordered: o3, o2, o1)
    model_choice = st.selectbox(
        texts["model_label"][ui_lang], 
        ["lexi-o3", "lexi-o2", "lexi-o1"], 
        index=0,
        help=texts["model_help"][ui_lang]
    )
    st.session_state.model = model_choice
    
    st.markdown("---")
    
    # Conversation controls - single button
    if st.button("🆕 Nouvelle conversation", key="new_conv", help="Commencer une nouvelle conversation", use_container_width=True):
        start_new_conversation(save_before=False)
        rerun()
    
    # Removed conversation history section for cleaner interface
    
    st.markdown("---")
    
    # Contact information
    st.markdown(f"""
    <div class="glass-card">
        <div class="contact-name">Cabinet Hila Ben Arbia</div>
        <div class="contact-info">
            {texts['foot_contact'][ui_lang]}
        </div>
    </div>
    """, unsafe_allow_html=True)

# ---------- MAIN HEADER ----------
st.markdown(f"""
<div class="glass-card">
    <div class="header-container">
        <div class="header-title">
            <img src="{LEXIBOT_AVATAR}" class="message-avatar" style="width: 60px; height: 60px;">
            {texts["title"][ui_lang]}
        </div>
        <div class="header-badge">
            ⚖️ {lang_flags[ui_lang]} {lang_names[ui_lang]}
        </div>
    </div>
</div>
""", unsafe_allow_html=True)

# Introduction text
st.markdown(f"""
<div class="glass-card">
    <div class="intro-text {('rtl' if ui_lang == 'ar' else 'ltr')}">
        {texts['intro'][ui_lang]}
    </div>
</div>
""", unsafe_allow_html=True)

# ---------- CATEGORY SELECTION (TOP) ----------
category_label = texts['category_label'][ui_lang]
category = st.selectbox(
    f"📂 {category_label}",
    categories[ui_lang],
    index=0,
    key="category_top"  # use a distinct key to avoid conflicts
)

# Show the selected category as an enhanced chip
selected_texts = { 'fr': '📂 Catégorie sélectionnée', 'en': '📂 Selected category', 'ar': '📂 التصنيف المختار' }
st.markdown(
    f"<div class='category-chip'>{selected_texts.get(ui_lang, 'Selected category')}: <strong>{category}</strong></div>",
    unsafe_allow_html=True,
)

# Add a subtle divider
st.markdown(
    "<div style='height: 1px; background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent); margin: 1.5rem 0;'></div>",
    unsafe_allow_html=True
)

# ---------- CHAT DISPLAY ----------
chat_container = st.container()
with chat_container:
    st.markdown('<div class="chat-container">', unsafe_allow_html=True)
    if not st.session_state.chat:
        # Welcome message when chat is empty
        welcome_msg = texts['intro'][ui_lang]
        from datetime import datetime as dt
        render_message("bot", welcome_msg, ui_lang, LEXIBOT_AVATAR, dt.now().strftime("%H:%M"))
    else:
        # Display all messages
        for msg in st.session_state.chat:
            avatar = USER_AVATAR if msg["role"] == "user" else LEXIBOT_AVATAR
            render_message(msg["role"], msg["text"], msg["lang"], avatar, msg["time"])

# Chat input with better spacing
st.markdown("<div style='margin-top: 2rem;'>", unsafe_allow_html=True)

with st.form("chat-input", clear_on_submit=True):
    # Message input
    user_text = st.text_area(
        " ",
        height=100,
        placeholder=texts["placeholder"][ui_lang],
        label_visibility="collapsed",
        key="user_input_area"
    )
    
    
    # Submit button - ALL of this must be indented to be inside the form
    col1, col2, col3 = st.columns([2, 1, 1])
    with col1:
        submit = st.form_submit_button(f"🚀 {texts['send'][ui_lang]}", use_container_width=True)
    with col2:
        clear_btn = st.form_submit_button(f"🧹 {texts['clear'][ui_lang]}")
    with col3:
        export_btn = st.form_submit_button(f"📥 {texts['export'][ui_lang]}")

# JavaScript pour gérer la touche Entrée - THIS is correctly outside the form
st.markdown("""
<script>
// Your JavaScript code...
</script>
""", unsafe_allow_html=True)

# ---------- HANDLE FORM ACTIONS ----------
if clear_btn:
    # Optionally clear without saving; keep explicit save controls in sidebar
    st.session_state.chat = []
    st.session_state.exported = False
    st.session_state.unsaved_changes = False
    rerun()

if export_btn:
    if st.session_state.chat:
        transcript_lines = []
        for m in st.session_state.chat:
            who = "YOU" if m["role"] == "user" else "LEXIBOT"
            transcript_lines.append(f"[{m['time']}] {who} ({m['lang']}|{m['category']}): {m['text']}")
        transcript = "\n".join(transcript_lines)
        
        st.download_button(
            label=f"📥 {texts['export'][ui_lang]}", 
            data=transcript, 
            file_name=f"lexibot_conversation_{dt.now().strftime('%Y%m%d_%H%M%S')}.txt",
            mime="text/plain"
        )
        st.session_state.exported = True
    else:
        st.warning("No conversation to export.")

# ---------- HANDLE MESSAGE SUBMISSION ----------
if submit:
    content = (user_text or "").strip()
    if not content:
        st.warning(texts["warning"][ui_lang])
    else:
        # Rate limiting - prevent multiple rapid requests
        current_time = time.time()
        if current_time - st.session_state.last_request < 2:  # 2 seconds between requests
            st.warning("Veuillez patienter avant d'envoyer une autre requête.")
        else:
            st.session_state.last_request = current_time
            
            st.session_state.last_interaction = time.time()
            # Language detection and routing
            chosen_lang = st.session_state.ui_lang
            detected = lang_detect_safe(content, chosen_lang)
            
            if auto_lang:
                chosen_lang = detected
                st.info(texts["detected_note"][st.session_state.ui_lang].format(
                    lang=f"{lang_flags[detected]} {lang_names.get(detected, detected)}"
                ))
            
            from datetime import datetime as dt
            now = dt.now().strftime("%H:%M")
            
            # Add user message
            st.session_state.chat.append({
                "role": "user",
                "text": content,
                "lang": chosen_lang,
                "category": category,
                "time": now
            })
            
            # Show typing indicator
            with chat_container:
                st.markdown('<div class="chat-container">', unsafe_allow_html=True)
                
                # Display all previous messages
                for msg in st.session_state.chat:
                    avatar = USER_AVATAR if msg["role"] == "user" else LEXIBOT_AVATAR
                    render_message(msg["role"], msg["text"], msg["lang"], avatar, msg["time"])
                
                # Show typing indicator
                typing_html = f"""
                <div class="message-row bot fade-in">
                    <img class="message-avatar" src="{LEXIBOT_AVATAR}" alt="bot">
                    <div class="message-bubble bot">
                        <div class="typing-indicator">
                            <span>{texts['typing'][chosen_lang]}</span>
                            <div class="typing-dots">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    </div>
                </div>
                """
                typing_placeholder = st.empty()
                typing_placeholder.markdown(typing_html, unsafe_allow_html=True)
                st.markdown(play_typing_sound(chosen_lang), unsafe_allow_html=True)
                st.markdown('</div>', unsafe_allow_html=True)
            
            # Get API response
            reply_text, raw = send_to_api(
                message=content,
                category=category,
                chosen_language=chosen_lang,
                model=st.session_state.model,
                stream=False
            )
            
            # Remove typing indicator
            typing_placeholder.empty()
            
            # Add bot response
            now_bot = dt.now().strftime("%H:%M")
            st.session_state.chat.append({
                "role": "bot",
                "text": reply_text,
                "lang": chosen_lang,
                "category": category,
                "time": now_bot
            })
            
            st.session_state.exported = False
            st.session_state.unsaved_changes = True
            st.session_state.last_interaction = time.time()
            rerun()

# ---------- FOOTER ----------
st.markdown(f"""
<div class="contact-card">
    <img src="{LEXIBOT_AVATAR}" class="message-avatar" style="width: 50px; height: 50px;">
    <div>
        <div class="contact-name">Cabinet Hila Ben Arbia</div>
        <div class="contact-info">{texts['foot_contact'][ui_lang]}</div>
    </div>
</div>
""", unsafe_allow_html=True)
