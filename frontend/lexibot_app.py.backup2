def register_client(first_name, last_name, email, phone, password):
    """Register a new client for Lexibot"""
    try:
        # Données structurées pour le schéma UserCreate de FastAPI-Users
        register_data = {
            "email": email,
            "password": password,
            "is_active": True,
            "is_superuser": False,
            "is_verified": False,
            "first_name": first_name,
            "last_name": last_name,
            "phone": phone,
            "preferred_language": "fr"
        }
        
        response = requests.post(
            f"{API_BASE_URL}/auth/register",  # Route définie dans app.include_router(fastapi_users.get_register_router...)
            json=register_data,
            timeout=10
        )
        
        # FastAPI-Users renvoie 201 Created
        if response.status_code == 201:
            return True, "Compte créé avec succès ! Connectez-vous."
        else:
            try:
                error_detail = response.json().get("detail", response.text)
            except:
                error_detail = response.text
            return False, f"Erreur: {error_detail}"
    except Exception as e:
        return False, f"Connexion impossible : {str(e)}"


def authenticate_client(email, password):
    """Authenticate client and get JWT token"""
    try:
        # FastAPI-Users / OAuth2 attend du form-data (data=)
        response = requests.post(
            f"{API_BASE_URL}/auth/jwt/login", # Route définie dans prefix="/auth/jwt"
            data={"username": email, "password": password},
            timeout=10
        )
        
        if response.status_code == 200:
            data = response.json()
            # On récupère aussi les infos de l'utilisateur pour le profil
            token = data["access_token"]
            user_res = requests.get(
                f"{API_BASE_URL}/users/me",
                headers={"Authorization": f"Bearer {token}"}
            )
            if user_res.status_code == 200:
                return True, {"token": token, "user": user_res.json()}
            return True, {"token": token, "user": {}}
        else:
            return False, "Email ou mot de passe incorrect"
    except Exception as e:
        return False, f"Erreur: {str(e)}"


# ============================
# 📅 APPOINTMENT FUNCTIONS
# ============================

def request_appointment(subject, preferred_date, preferred_time, description):
    """Request an appointment"""
    try:
        jwt_token = st.session_state.get("jwt_token", "")
        if not jwt_token:
            return False, "Veuillez vous connecter"
        
        # Formatage de la date en ISO (FastAPI préfère ça)
        # preferred_date est un objet dt.date, on le combine avec l'heure
        datetime_str = f"{preferred_date}T{preferred_time}:00"
        
        appointment_data = {
            "subject": subject,
            "preferred_date": datetime_str,
            "description": description or ""
        }
        
        response = requests.post(
            f"{API_BASE_URL}/appointments/request",
            json=appointment_data,
            headers={"Authorization": f"Bearer {jwt_token}"},
            timeout=10
        )
        
        if response.status_code in [200, 201]:
            return True, "Rendez-vous demandé avec succès"
        else:
            return False, f"Erreur: {response.text}"
    except Exception as e:
        return False, f"Erreur: {str(e)}"


def get_user_appointments():
    """Get user's appointments"""
    try:
        jwt_token = st.session_state.get("jwt_token", "")
        if not jwt_token:
            return []
        
        response = requests.get(
            f"{API_BASE_URL}/appointments/my",
            headers={"Authorization": f"Bearer {jwt_token}"},
            timeout=10
        )
        
        if response.status_code == 200:
            return response.json()
        else:
            return []
    except Exception:
        return []


