def authenticate_client(email, password):
    """Authenticate client and return token + user info"""
    try:
        import requests
        # On passe un dictionnaire à 'data', requests s'occupe du Content-Type
        login_data = {
            "username": email,
            "password": password
        }
        
        response = requests.post(
            f"{API_BASE_URL}/auth/jwt/login",
            data=login_data,
            timeout=10
        )

        if response.status_code == 200:
            token = response.json()["access_token"]
            
            # Récupération des infos de l'utilisateur (le /me)
            user_response = requests.get(
                f"{API_BASE_URL}/users/me",
                headers={"Authorization": f"Bearer {token}"},
                timeout=5
            )
            
            if user_response.status_code == 200:
                user_info = user_response.json()
                return True, {"token": token, "user": user_info}
            else:
                return False, "Session établie, mais profil introuvable."
        
        elif response.status_code == 400:
            return False, "Email ou mot de passe incorrect."
        else:
            return False, f"Erreur serveur ({response.status_code})"
            
    except Exception as e:
        return False, f"Erreur de connexion : {str(e)}"

def register_client(first_name, last_name, email, phone, password):
    """Register new client for Lexibot"""
    try:
        import requests
        
        # Données structurées pour ton schéma UserCreate (pydantic)
        register_data = {
            "email": email,
            "password": password,
            "is_active": True,
            "is_superuser": False,
            "is_verified": False,
            "first_name": first_name,
            "last_name": last_name,
            "phone": phone,
            "preferred_language": "fr"
        }

        response = requests.post(
            f"{API_BASE_URL}/auth/register",
            json=register_data,
            timeout=10
        )

        if response.status_code == 201:
            return True, "Compte créé avec succès ! Connectez-vous maintenant."
        
        elif response.status_code == 400:
            detail = response.json().get("detail", "")
            if "REGISTER_USER_ALREADY_EXISTS" in str(detail):
                return False, "Cet email est déjà enregistré au cabinet."
            return False, f"Données invalides : {detail}"
        else:
            return False, f"Erreur ({response.status_code}): {response.text}"

    except Exception as e:
        return False, f"Impossible de joindre le backend : {str(e)}"

