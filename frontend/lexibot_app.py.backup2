)

# ---------- HELPER FUNCTIONS ----------
def escape_to_html(text: str) -> str:
    """Enhanced HTML escaping with URL detection"""
    def url_repl(m):
        url = m.group(0)
        return f'<a href="{url}" target="_blank" style="color: var(--accent-green); text-decoration: underline;">{url}</a>'
    
    # Remove markdown formatting
    text = re.sub(r'\*\*(.*?)\*\*', r'\1', text)
    text = re.sub(r'\*(.*?)\*', r'\1', text)
    text = re.sub(r'__(.*?)__', r'\1', text)
    text = re.sub(r'_(.*?)_', r'\1', text)
    
    text = html.escape(text)
    text = re.sub(r"(https?://[^\s]+)", url_repl, text)
    text = text.replace("\n", "<br>")
    return text

def lang_detect_safe(text: str, fallback: str) -> str:
    """Safe language detection"""
    try:
        detected = detect(text)
        if detected.startswith("fr"):
            return "fr"
        if detected.startswith("en"):
            return "en"
        if detected.startswith("ar"):
            return "ar"
        return fallback
    except Exception:
        return fallback


def authenticate(username, password):
    # The login URL is correctly constructed here.
    login_url = f"{API_BASE_URL}/auth/jwt/login" 
    
    try:
        # Use data= for x-www-form-urlencoded
        response = requests.post(
            login_url,
            data={"username": username, "password": password}
        )
        if response.status_code == 200:
            token = response.json().get("access_token")
            st.session_state.auth_token = token
            st.session_state.is_authenticated = True
            st.success("Connexion réussie! Vous êtes connecté.")
            return True
        else:
            # <<< CRITICAL DEBUG CHANGE: Display the full API response for non-200 codes >>>
            st.error(f"Échec de la connexion. Code: {response.status_code}. Réponse API: {response.text}")
            return False
    except requests.exceptions.ConnectionError:
        # <<< CRITICAL DEBUG CHANGE: Show the full URL being targeted >>>
        st.error(f"Erreur de connexion à l'API. Assurez-vous que le serveur est accessible à {API_BASE_URL}")
        return False
    
    
def send_to_api(message: str, category: str, chosen_language: str, model: str = MODEL_DEFAULT, stream=False):
    # 1. Standardize on the correct token variable (auth_token)
    token = st.session_state.auth_token
    
    # 2. Check for the token and handle the Unauthorized case early
    if not token:
        st.error("Token non trouvé. Veuillez vous reconnecter.")
        # Return a message telling the user to re-authenticate
        return "🔐 Session expirée ou non connectée. Veuillez vous reconnecter via la barre latérale, puis réessayez.", None
        
    # 3. Create the headers dictionary correctly using the valid token
    headers = {
        "Authorization": f"Bearer {token}",
        "accept": "application/json",
        "Content-Type": "application/json",
    }
    
    """Enhanced API communication with better error handling"""
    try:
        actual_model = MODEL_MAPPING.get(model, MODEL_MAPPING[MODEL_DEFAULT])
        
        response = requests.post(
            API_URL, # Ensure API_URL is defined as a constant globally
            json={
                "message": message,
                "model": actual_model,
                "stream": stream,
                "category": category,
                "chosen_language": chosen_language
            },
            timeout=30,  # Reasonable timeout
            headers=headers # <-- USE THE CORRECT, AUTHENTICATED HEADERS
        )

        # Explicit 401 handling (still good to keep for clarity)
        if response.status_code == 401:
            # This should technically not be hit if the token check above is correct, 
            # but is useful for expired tokens.
            return "🔐 Session expirée. Veuillez vous reconnecter.", None
            
        response.raise_for_status() # Raises an HTTPError for bad responses (4xx or 5xx)
        data = response.json()
        
        # ... (Rest of your excellent response parsing logic remains the same) ...
        if isinstance(data, dict) and "response" in data:
            return data["response"], data
        # ... (The rest of your response parsing logic) ...
        # ...
        
    except requests.exceptions.ConnectionError as e:
        return "🔌 Impossible de se connecter à l'API. Vérifiez que le serveur API est démarré sur http://backend:8000", None
    except requests.exceptions.Timeout as e:
        return "⏰ Délai d'attente dépassé. Le serveur API met trop de temps à répondre.", None
    except requests.exceptions.RequestException as e:
        return f"❌ Erreur réseau/API : {str(e)[:100]}...", None
    except Exception as e:
        return f"❌ Erreur inattendue : {str(e)[:100]}...", None
    
    
    
def render_message(role: str, text: str, lang: str, avatar_url: str, timestamp: str):
    """Enhanced message rendering with proper text alignment"""
    # Force left alignment for French/English, right for Arabic only
    text_direction = "rtl" if lang == "ar" else "ltr"
    text_align = "right" if lang == "ar" else "left"
    
    html_content = f"""
    <div class="message-row {role} fade-in">
        <img class="message-avatar" src="{avatar_url}" alt="{role}">
        <div class="message-bubble {role}" style="direction: {text_direction}; text-align: {text_align};">
            <div class="message-content" style="direction: {text_direction}; text-align: {text_align};">
                {escape_to_html(text)}
            </div>
            <div class="message-time">{timestamp}</div>
        </div>
    </div>
    """
    st.markdown(html_content, unsafe_allow_html=True)

